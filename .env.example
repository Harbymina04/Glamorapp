# Database
DATABASE_URL=postgresql://glamorapp:glamorapp_dev@localhost:5432/glamorapp

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-secret-key-min-32-chars-change-me
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Storage (MinIO / S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=glamorapp
S3_PUBLIC_URL=http://localhost:9000/glamorapp

# AI
ANTHROPIC_API_KEY=sk-ant-xxx
AI_MODEL=claude-sonnet-4-20250514

# Email (SMTP) — leave SMTP_HOST empty to disable email sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-app-password
SMTP_FROM=Glamorapp <no-reply@glamorapp.com>

# Wompi (pasarela de pago Colombia)
# Obtén tus llaves en https://comercios.wompi.co
# WOMPI_ENV=sandbox para pruebas, production para producción
WOMPI_ENV=sandbox
WOMPI_PUBLIC_KEY=pub_test_xxxxxxxxxxxxxxxxxxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxxxxxxxxxxxxxxxxxx
WOMPI_INTEGRITY_KEY=test_integrity_xxxxxxxxxxxxxxxx
WOMPI_EVENTS_KEY=test_events_xxxxxxxxxxxxxxxx
# Webhook URL a registrar en el dashboard de Wompi:
# https://tudominio.com/api/v1/payments/webhook

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
PORT=3001
NODE_ENV=development

# Horas que una venta pendiente puede retener stock antes de expirar
# automáticamente y devolver el stock al inventario (default: 24).
SALE_HOLD_EXPIRY_HOURS=24
