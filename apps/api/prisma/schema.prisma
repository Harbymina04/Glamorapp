generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────

enum UserRole {
  superadmin
  tenant_admin
  store_admin
  cashier
  professional
  financial
  readonly
}

enum ProductStatus {
  active
  inactive
}

enum InventoryMovementType {
  entry
  exit
  adjustment
  transfer
}

enum SaleStatus {
  pending
  completed
  cancelled
  refunded
}

enum PaymentMethod {
  cash
  card
  transfer
  mixed
  other
}

enum AppointmentStatus {
  pending
  confirmed
  in_progress
  completed
  cancelled
  no_show
}

enum ExpenseStatus {
  paid
  pending
  cancelled
}

enum RecurrenceType {
  none
  daily
  weekly
  biweekly
  monthly
  yearly
}

enum CustomerSegment {
  new
  frequent
  inactive
  vip
}

enum LoyaltyTier {
  bronze
  silver
  gold
  platinum
}

enum SupplierStatus {
  active
  inactive
}

enum AgentStatus {
  active
  paused
  pending_config
  error
}

enum AgentAutonomy {
  recommend_only
  recommend_and_draft
  execute_with_approval
  auto_execute
}

enum RecommendationStatus {
  pending
  accepted
  rejected
  expired
}

enum NotificationType {
  info
  warning
  error
  success
}

enum AuditAction {
  create
  update
  delete
  login
  logout
  sale
  void_sale
  inventory_change
  config_change
  ai_action
}

enum NailDesignCategory {
  classic
  decorated
  artistic
  modern
  trending
  minimalist
  seasonal
}

enum PurchaseStatus {
  pending
  received
  partial
  cancelled
}

enum CashRegisterSessionStatus {
  open
  closed
}

enum CashMovementType {
  in
  out
}

// ─── Core Multi-tenancy ──────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  plan      String   @default("free") @db.VarChar(50)
  isActive  Boolean  @default(true) @map("is_active")
  settings         Json     @default("{}")
  marketingConfig  Json     @default("{}") @map("marketing_config")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stores    Store[]
  users     User[]
  subscriptions Subscription[]
  aiUsages  AiUsage[]
  fiscalConfigs      FiscalConfig[]
  commissions        Commission[]
  taxRates           TaxRate[]
  invoices           Invoice[]
  accountingTx       AccountingTransaction[]
  taxDeclarations    TaxDeclaration[]
  storefront         Storefront?
  storefrontOrders   StorefrontOrder[]
  storefrontReviews  StorefrontReview[]

  @@map("tenants")
}

model Store {
  id                     String    @id @default(uuid()) @db.Uuid
  tenantId               String    @map("tenant_id") @db.Uuid
  tenant                 Tenant    @relation(fields: [tenantId], references: [id])
  name                   String    @db.VarChar(255)
  slug                   String    @db.VarChar(100)
  logoUrl                String?   @map("logo_url")
  slogan                 String?   @db.VarChar(255)
  email                  String?   @db.VarChar(255)
  phone                  String?   @db.VarChar(50)
  address                String?
  city                   String?   @db.VarChar(100)
  state                  String?   @db.VarChar(100)
  country                String?   @db.VarChar(100)
  zipCode                String?   @map("zip_code") @db.VarChar(20)
  currency               String    @default("MXN") @db.VarChar(10)
  timezone               String    @default("America/Mexico_City") @db.VarChar(50)
  locale                 String    @default("es") @db.VarChar(10)
  dateFormat             String    @default("DD/MM/YYYY") @map("date_format") @db.VarChar(20)
  timeFormat             String    @default("12h") @map("time_format") @db.VarChar(20)
  unitSystem             String    @default("metric") @map("unit_system") @db.VarChar(20)
  primaryColor           String    @default("#FF2D8E") @map("primary_color") @db.VarChar(7)
  theme                  String    @default("light") @db.VarChar(10)
  taxInclusive           Boolean   @default(true) @map("tax_inclusive")
  allowDiscounts         Boolean   @default(true) @map("allow_discounts")
  autoPrintReceipt       Boolean   @default(false) @map("auto_print_receipt")
  requireCustomerOnSale  Boolean   @default(false) @map("require_customer_on_sale")
  lowStockAlert          Boolean   @default(true) @map("low_stock_alert")
  defaultPage            String    @default("dashboard") @map("default_page") @db.VarChar(50)
  sessionDurationMinutes Int       @default(60) @map("session_duration_minutes")
  initialFolioNumber     Int       @default(1) @map("initial_folio_number")
  isActive               Boolean   @default(true) @map("is_active")
  isStoreVisible            Boolean  @default(false) @map("is_store_visible")
  latitude                  Decimal? @db.Decimal(10, 7)
  longitude                 Decimal? @db.Decimal(10, 7)
  neighborhood              String?  @db.VarChar(100)
  acceptsPickup             Boolean  @default(true) @map("accepts_pickup")
  acceptsOnlineAppointments Boolean  @default(true) @map("accepts_online_appointments")
  businessHours          Json      @default("{}") @map("business_hours")
  invoiceTemplate        Json      @default("{}") @map("invoice_template")
  ticketTemplate         Json      @default("{}") @map("ticket_template")
  posSettings            Json      @default("{}") @map("pos_settings")
  whatsappNumber        String?   @map("whatsapp_number") @db.VarChar(20)
  whatsappSessionId     String?   @map("whatsapp_session_id") @db.VarChar(100)
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  users        User[]
  products     Product[]
  productCategories ProductCategory[]
  brands       Brand[]
  sales        Sale[]
  services     Service[]
  appointments Appointment[]
  nailDesigns  NailDesign[]
  customers    Customer[]
  suppliers    Supplier[]
  purchases    Purchase[]
  expenses     Expense[]
  aiAgents     AiAgent[]
  packages     Package[]
  cashRegisterSessions CashRegisterSession[]
  cashRegisters CashRegister[]
  permissions  Permission[]
  aiUsages     AiUsage[]
  fiscalConfig       FiscalConfig[]
  commissions        Commission[]
  invoices           Invoice[]
  accountingTx       AccountingTransaction[]
  storefrontOrders   StorefrontOrder[]
  storefrontReviews  StorefrontReview[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("stores")
}

// ─── Auth ────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  storeId      String?   @map("store_id") @db.Uuid
  store        Store?    @relation(fields: [storeId], references: [id])
  email        String    @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  firstName    String    @map("first_name") @db.VarChar(100)
  lastName     String    @map("last_name") @db.VarChar(100)
  phone        String?   @db.VarChar(50)
  avatarUrl    String?   @map("avatar_url")
  role         UserRole  @default(cashier)
  commissionRate    Decimal   @default(0) @map("commission_rate") @db.Decimal(5, 2)
  isActive          Boolean   @default(true) @map("is_active")
  lastLoginAt       DateTime? @map("last_login_at")
  failedLoginCount  Int       @default(0) @map("failed_login_count")
  lockedUntil       DateTime? @map("locked_until")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  permissions        Permission[]
  refreshTokens       RefreshToken[]
  passwordResets      PasswordReset[]
  sales               Sale[]
  professionalAppointments Appointment[] @relation("ProfessionalAppointments")
  sessionsOpened      CashRegisterSession[] @relation("CashRegisterOpenedBy")
  sessionsClosed      CashRegisterSession[] @relation("CashRegisterClosedBy")
  saleItemsPerformed  SaleItem[]   @relation("PerformedBy")
  commissions         Commission[]
  commissionsPaid     Commission[] @relation("PaidBy")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, email])
  @@map("users")
}

model Permission {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  storeId   String?  @map("store_id") @db.Uuid
  store     Store?   @relation(fields: [storeId], references: [id])
  module    String   @db.VarChar(50)
  canView   Boolean  @default(false) @map("can_view")
  canCreate Boolean  @default(false) @map("can_create")
  canEdit   Boolean  @default(false) @map("can_edit")
  canDelete Boolean  @default(false) @map("can_delete")
  canExport Boolean  @default(false) @map("can_export")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, userId, module])
  @@map("permissions")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Products & Inventory ────────────────────────────────────────

model ProductCategory {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  storeId   String   @map("store_id") @db.Uuid
  store     Store    @relation(fields: [storeId], references: [id])
  name      String   @db.VarChar(100)
  icon      String?  @db.VarChar(50)
  color     String?  @db.VarChar(7)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]

  @@unique([tenantId, storeId, name])
  @@map("product_categories")
}

model Brand {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  storeId      String   @map("store_id") @db.Uuid
  store        Store    @relation(fields: [storeId], references: [id])
  name         String   @db.VarChar(100)
  logoUrl      String?  @map("logo_url")
  productCount Int      @default(0) @map("product_count")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  products Product[]

  @@unique([tenantId, storeId, name])
  @@map("brands")
}

model Product {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  storeId         String        @map("store_id") @db.Uuid
  store           Store         @relation(fields: [storeId], references: [id])
  categoryId      String?       @map("category_id") @db.Uuid
  category        ProductCategory? @relation(fields: [categoryId], references: [id])
  brandId         String?       @map("brand_id") @db.Uuid
  brand           Brand?        @relation(fields: [brandId], references: [id])
  name            String        @db.VarChar(255)
  description     String?
  sku             String?       @db.VarChar(50)
  barcode         String?       @db.VarChar(100)
  imageUrl        String?       @map("image_url")
  costPrice       Decimal       @default(0) @map("cost_price") @db.Decimal(12, 2)
  salePrice       Decimal       @map("sale_price") @db.Decimal(12, 2)
  currentStock    Int           @default(0) @map("current_stock")
  minStock        Int           @default(0) @map("min_stock")
  unitOfMeasure   String        @default("unit") @map("unit_of_measure") @db.VarChar(20)
  size            String?       @db.VarChar(50)
  status          ProductStatus @default(active)
  isFeatured      Boolean       @default(false) @map("is_featured")
  isCatalogVisible Boolean      @default(true) @map("is_catalog_visible")
  catalogViews    Int           @default(0) @map("catalog_views")
  isStoreVisible   Boolean  @default(false) @map("is_store_visible")
  storeDescription String?  @map("store_description")
  storeSortOrder   Int      @default(0) @map("store_sort_order")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  inventoryMovements InventoryMovement[]
  saleItems          SaleItem[]
  purchaseItems      PurchaseItem[]
  supplierProducts   SupplierProduct[]
  images             ProductImage[]
  invoiceItems       InvoiceItem[]

  @@unique([tenantId, storeId, sku])
  @@index([tenantId, storeId])
  @@index([categoryId])
  @@index([brandId])
  @@index([tenantId, storeId, sku])
  @@index([tenantId, storeId, status])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String   @db.VarChar(500)
  filename  String   @db.VarChar(255)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@map("product_images")
}

model InventoryMovement {
  id             String                 @id @default(uuid()) @db.Uuid
  tenantId       String                 @map("tenant_id") @db.Uuid
  storeId        String                 @map("store_id") @db.Uuid
  productId      String                 @map("product_id") @db.Uuid
  product        Product                @relation(fields: [productId], references: [id])
  movementType   InventoryMovementType  @map("movement_type")
  quantity       Int
  previousStock  Int                    @map("previous_stock")
  newStock       Int                    @map("new_stock")
  referenceType  String?                @map("reference_type") @db.VarChar(50)
  referenceId    String?                @map("reference_id") @db.Uuid
  notes          String?
  createdBy      String?                @map("created_by") @db.Uuid
  createdAt      DateTime               @default(now()) @map("created_at")

  @@index([tenantId, productId])
  @@index([tenantId, storeId, createdAt])
  @@map("inventory_movements")
}

// ─── Sales ───────────────────────────────────────────────────────

model Sale {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @map("tenant_id") @db.Uuid
  storeId         String     @map("store_id") @db.Uuid
  store           Store      @relation(fields: [storeId], references: [id])
  customerId      String?    @map("customer_id") @db.Uuid
  customer        Customer?  @relation(fields: [customerId], references: [id])
  userId          String     @map("user_id") @db.Uuid
  user            User       @relation(fields: [userId], references: [id])
  saleNumber      String     @map("sale_number") @db.VarChar(20)
  status          SaleStatus @default(pending)
  subtotal        Decimal    @default(0) @db.Decimal(12, 2)
  discountPercent Decimal    @default(0) @map("discount_percent") @db.Decimal(5, 2)
  discountAmount  Decimal    @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxPercent      Decimal    @default(16) @map("tax_percent") @db.Decimal(5, 2)
  taxAmount       Decimal    @default(0) @map("tax_amount") @db.Decimal(12, 2)
  total           Decimal    @default(0) @db.Decimal(12, 2)
  notes           String?
  completedAt     DateTime?  @map("completed_at")
  cancelledAt     DateTime?  @map("cancelled_at")
  cancelledReason String?    @map("cancelled_reason")
  refundedAt      DateTime?  @map("refunded_at")
  refundReason    String?    @map("refund_reason")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  items         SaleItem[]
  payments      Payment[]
  appointments  Appointment[] @relation("AppointmentSale")
  invoices      Invoice[]
  commissions   Commission[]
  accountingTx  AccountingTransaction[]
  requiresInvoice Boolean  @default(false) @map("requires_invoice")
  invoiceId       String?  @map("invoice_id") @db.Uuid

  @@unique([tenantId, storeId, saleNumber])
  @@index([tenantId, storeId])
  @@index([customerId])
  @@index([tenantId, storeId, createdAt])
  @@index([tenantId, storeId, status])
  @@map("sales")
}

model SaleItem {
  id             String   @id @default(uuid()) @db.Uuid
  saleId         String   @map("sale_id") @db.Uuid
  sale           Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId      String?  @map("product_id") @db.Uuid
  product        Product? @relation(fields: [productId], references: [id])
  serviceId      String?  @map("service_id") @db.Uuid
  service        Service? @relation(fields: [serviceId], references: [id])
  itemType       String   @default("product") @map("item_type") @db.VarChar(20)
  name           String   @db.VarChar(255)
  quantity       Int      @default(1)
  unitPrice      Decimal  @map("unit_price") @db.Decimal(12, 2)
  discountAmount Decimal  @default(0) @map("discount_amount") @db.Decimal(12, 2)
  total          Decimal  @db.Decimal(12, 2)
  // Commission fields (only for services)
  performedBy    String?  @map("performed_by") @db.Uuid
  performer      User?    @relation("PerformedBy", fields: [performedBy], references: [id])
  commissionRate Decimal  @default(0) @map("commission_rate") @db.Decimal(5, 2)
  commissionAmount Decimal @default(0) @map("commission_amount") @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  commissions    Commission[]

  @@index([saleId])
  @@index([performedBy])
  @@map("sale_items")
}

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  saleId        String        @map("sale_id") @db.Uuid
  sale          Sale          @relation(fields: [saleId], references: [id])
  paymentMethod PaymentMethod @map("payment_method")
  amount        Decimal       @db.Decimal(12, 2)
  reference     String?       @db.VarChar(100)
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")

  @@index([saleId])
  @@map("payments")
}

// ─── Services & Appointments ─────────────────────────────────────

model Service {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  storeId         String   @map("store_id") @db.Uuid
  store           Store    @relation(fields: [storeId], references: [id])
  name            String   @db.VarChar(255)
  description     String?
  category        String?  @db.VarChar(100)
  price           Decimal  @db.Decimal(12, 2)
  durationMinutes Int      @default(60) @map("duration_minutes")
  color           String   @default("#EF2D8F") @db.VarChar(7)
  commissionRate  Decimal  @default(0) @map("commission_rate") @db.Decimal(5, 2)
  isActive        Boolean  @default(true) @map("is_active")
  isStoreVisible      Boolean @default(false) @map("is_store_visible")
  storeDescription    String? @map("store_description")
  allowsOnlineBooking Boolean @default(false) @map("allows_online_booking")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  appointments Appointment[]
  saleItems    SaleItem[]
  invoiceItems InvoiceItem[]

  @@index([tenantId, storeId])
  @@map("services")
}

model Commission {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  storeId        String    @map("store_id") @db.Uuid
  store          Store     @relation(fields: [storeId], references: [id])
  userId         String    @map("user_id") @db.Uuid
  user           User      @relation(fields: [userId], references: [id])
  saleId         String?   @map("sale_id") @db.Uuid
  sale           Sale?     @relation(fields: [saleId], references: [id])
  saleItemId     String?   @map("sale_item_id") @db.Uuid
  saleItem       SaleItem? @relation(fields: [saleItemId], references: [id])
  serviceName    String    @map("service_name") @db.VarChar(255)
  baseAmount     Decimal   @map("base_amount") @db.Decimal(12, 2)
  commissionRate Decimal   @map("commission_rate") @db.Decimal(5, 2)
  amount         Decimal   @db.Decimal(12, 2)
  status         String    @default("pending") @db.VarChar(20)
  periodStart    DateTime? @map("period_start") @db.Date
  periodEnd      DateTime? @map("period_end") @db.Date
  paidAt         DateTime? @map("paid_at")
  paidById       String?   @map("paid_by") @db.Uuid
  paidBy         User?     @relation("PaidBy", fields: [paidById], references: [id])
  paymentNotes   String?   @map("payment_notes")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([userId])
  @@index([storeId])
  @@index([status])
  @@index([saleId])
  @@map("commissions")
}

model Appointment {
  id             String            @id @default(uuid()) @db.Uuid
  tenantId       String            @map("tenant_id") @db.Uuid
  storeId        String            @map("store_id") @db.Uuid
  store          Store             @relation(fields: [storeId], references: [id])
  customerId     String            @map("customer_id") @db.Uuid
  customer       Customer          @relation(fields: [customerId], references: [id])
  professionalId String            @map("professional_id") @db.Uuid
  professional   User              @relation("ProfessionalAppointments", fields: [professionalId], references: [id])
  serviceId      String            @map("service_id") @db.Uuid
  service        Service           @relation(fields: [serviceId], references: [id])
  nailDesignId   String?           @map("nail_design_id") @db.Uuid
  nailDesign     NailDesign?       @relation(fields: [nailDesignId], references: [id])
  saleId         String?           @map("sale_id") @db.Uuid
  sale           Sale?             @relation("AppointmentSale", fields: [saleId], references: [id])
  date           DateTime          @db.Date
  startTime      String            @map("start_time")
  endTime        String            @map("end_time")
  status         AppointmentStatus @default(pending)
  price          Decimal           @db.Decimal(12, 2)
  notes          String?
  originChannel  String            @default("manual") @map("origin_channel") @db.VarChar(50)
  confirmedAt    DateTime?         @map("confirmed_at")
  completedAt    DateTime?         @map("completed_at")
  cancelledAt    DateTime?         @map("cancelled_at")
  cancelReason   String?           @map("cancel_reason")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@index([tenantId, storeId])
  @@index([tenantId, storeId, date])
  @@index([professionalId, date])
  @@index([customerId])
  @@index([tenantId, storeId, status])
  @@map("appointments")
}

// ─── Nail Designs ────────────────────────────────────────────────

model NailDesign {
  id                        String            @id @default(uuid()) @db.Uuid
  tenantId                  String            @map("tenant_id") @db.Uuid
  storeId                   String            @map("store_id") @db.Uuid
  store                     Store             @relation(fields: [storeId], references: [id])
  name                      String            @db.VarChar(255)
  imageUrl                  String?           @map("image_url")
  category                  NailDesignCategory @default(classic)
  technique                 String?           @db.VarChar(100)
  colors                    Json              @default("[]")
  suggestedPrice            Decimal?          @map("suggested_price") @db.Decimal(12, 2)
  estimatedDurationMinutes  Int?              @map("estimated_duration_minutes")
