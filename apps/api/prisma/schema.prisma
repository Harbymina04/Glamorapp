model Subscription {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  planId        String    @map("plan_id") @db.Uuid
  plan          Plan      @relation(fields: [planId], references: [id])
  status        String    @default("trial") @db.VarChar(20)
  billingCycle  String    @default("monthly") @map("billing_cycle") @db.VarChar(10)
  trialEndsAt   DateTime? @map("trial_ends_at")
  currentPeriodStart DateTime? @map("current_period_start")
  currentPeriodEnd   DateTime? @map("current_period_end")
  cancelledAt   DateTime? @map("cancelled_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("subscriptions")
}

model PaymentException {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  type          String    @db.VarChar(30)
  description   String?   @db.Text
  amount        Decimal   @default(0) @db.Decimal(12, 2)
  status        String    @default("pending") @db.VarChar(20)
  approvedBy    String?   @map("approved_by") @db.Uuid
  validFrom     DateTime? @map("valid_from")
  validUntil    DateTime? @map("valid_until")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([tenantId, status])
  @@map("payment_exceptions")
}

// ─── Password Reset ─────────────────────────────────────────────

model PasswordReset {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id])
  token     String    @unique @db.VarChar(500)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([token])
  @@map("password_resets")
}

// ─── AI Usage Metrics ───────────────────────────────────────────

model AiUsage {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  storeId       String?  @map("store_id") @db.Uuid
  store         Store?   @relation(fields: [storeId], references: [id])
  agentId       String?  @map("agent_id") @db.Uuid
  agent         AiAgent? @relation(fields: [agentId], references: [id])
  actionType    String   @map("action_type") @db.VarChar(50)
  modelName     String   @map("model_name") @db.VarChar(100)
  tokensIn      Int      @default(0) @map("tokens_in")
  tokensOut     Int      @default(0) @map("tokens_out")
  costEstimated Decimal  @default(0) @map("cost_estimated") @db.Decimal(10, 4)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([storeId, createdAt])
  @@index([agentId, createdAt])
  @@map("ai_usage")
}

// ─── Accounting Module Enums ────────────────────────────────────

enum InvoiceType {
  invoice
  credit_note
  debit_note
  support_document
  pos_invoice
}

enum InvoiceStatus {
  draft
  pending_dian
  approved
  rejected
  cancelled
}

enum TaxType {
  iva
  ica
  retefuente
  reteiva
  reteica
}

enum PersonType {
  natural
  juridica
}

enum TaxRegime {
  responsable_iva
  no_responsable
  gran_contribuyente
  regimen_simple
}

enum IdType {
  cc
  nit
  ce
  pasaporte
  ti
  pep
}

enum AccountingTransactionType {
  income
  expense
  transfer
  tax_payment
  adjustment
}

enum AccountingTransactionStatus {
  confirmed
  pending
  voided
}

// ─── Fiscal Config ──────────────────────────────────────────────

model FiscalConfig {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @unique @map("tenant_id") @db.Uuid
  tenant      Tenant  @relation(fields: [tenantId], references: [id])
  // storeId is nullable — fiscal config belongs to the tenant, not a specific store
  storeId     String? @map("store_id") @db.Uuid
  store       Store?  @relation(fields: [storeId], references: [id])

  businessName           String     @map("business_name") @db.VarChar(255)
  tradeName              String?    @map("trade_name") @db.VarChar(255)
  idType                 IdType     @default(nit) @map("id_type")
  idNumber               String     @map("id_number") @db.VarChar(20)
  dv                     String?    @db.Char(1)
  personType             PersonType @default(juridica) @map("person_type")
  taxRegime              TaxRegime  @default(responsable_iva) @map("tax_regime")

  fiscalAddress          String   @default("") @map("fiscal_address")
  cityCode               String?  @map("city_code") @db.VarChar(10)
  departmentCode         String?  @map("department_code") @db.VarChar(10)
  countryCode            String   @default("CO") @map("country_code") @db.VarChar(3)
  postalCode             String?  @map("postal_code") @db.VarChar(10)

  fiscalEmail            String   @default("") @map("fiscal_email") @db.VarChar(255)
  fiscalPhone            String?  @map("fiscal_phone") @db.VarChar(50)
  taxResponsibilities    Json     @default("[]") @map("tax_responsibilities")

  economicActivityCode   String?  @map("economic_activity_code") @db.VarChar(10)
  economicActivityDesc   String?  @map("economic_activity_desc") @db.VarChar(255)

  feProvider             String   @default("none") @map("fe_provider") @db.VarChar(50)
  feProviderApiKey       String?  @map("fe_provider_api_key") @db.VarChar(500)
  feProviderApiSecret    String?  @map("fe_provider_api_secret") @db.VarChar(500)
  feEnvironment          String   @default("sandbox") @map("fe_environment") @db.VarChar(20)
  feProviderConfig       Json     @default("{}") @map("fe_provider_config")

  resolutionNumber       String?  @map("resolution_number") @db.VarChar(50)
  resolutionDate         DateTime? @map("resolution_date") @db.Date
  resolutionPrefix       String?  @map("resolution_prefix") @db.VarChar(10)
  resolutionFrom         Int?     @map("resolution_from")
  resolutionTo           Int?     @map("resolution_to")
  resolutionValidFrom    DateTime? @map("resolution_valid_from") @db.Date
  resolutionValidTo      DateTime? @map("resolution_valid_to") @db.Date
  currentInvoiceNumber   Int      @default(0) @map("current_invoice_number")

  cnPrefix               String?  @map("cn_prefix") @db.VarChar(10)
  cnCurrentNumber        Int      @default(0) @map("cn_current_number")
  dnPrefix               String?  @map("dn_prefix") @db.VarChar(10)
  dnCurrentNumber        Int      @default(0) @map("dn_current_number")

  isActive               Boolean  @default(true) @map("is_active")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  invoices               Invoice[]

  @@index([tenantId])
  @@map("fiscal_config")
}

// ─── Tax Rates ──────────────────────────────────────────────────

model TaxRate {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String   @db.VarChar(100)
  taxType       TaxType  @map("tax_type")
  rate          Decimal  @db.Decimal(5, 2)
  isDefault     Boolean  @default(false) @map("is_default")
  isActive      Boolean  @default(true) @map("is_active")
  appliesTo     String   @default("all") @map("applies_to") @db.VarChar(20)
  minBaseAmount Decimal  @default(0) @map("min_base_amount") @db.Decimal(12, 2)
  dianTaxCode   String?  @map("dian_tax_code") @db.VarChar(10)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("tax_rates")
}

// ─── Invoices ───────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  storeId        String        @map("store_id") @db.Uuid
  store          Store         @relation(fields: [storeId], references: [id])
  saleId         String?       @map("sale_id") @db.Uuid
  sale           Sale?         @relation(fields: [saleId], references: [id])
  purchaseId     String?       @map("purchase_id") @db.Uuid
  purchase       Purchase?     @relation(fields: [purchaseId], references: [id])
  fiscalConfigId String?       @map("fiscal_config_id") @db.Uuid
  fiscalConfig   FiscalConfig? @relation(fields: [fiscalConfigId], references: [id])

  invoiceType    InvoiceType   @default(invoice) @map("invoice_type")
  invoiceNumber  String        @map("invoice_number") @db.VarChar(30)
  prefix         String?       @db.VarChar(10)
  consecutive    Int

  referencedInvoiceId String?   @map("referenced_invoice_id") @db.Uuid
  referencedInvoice   Invoice?  @relation("InvoiceRef", fields: [referencedInvoiceId], references: [id])
  creditNotes         Invoice[] @relation("InvoiceRef")
  correctionReason    String?   @map("correction_reason")

  customerId     String?   @map("customer_id") @db.Uuid
  customer       Customer? @relation(fields: [customerId], references: [id])
  supplierId     String?   @map("supplier_id") @db.Uuid
  supplier       Supplier? @relation(fields: [supplierId], references: [id])

  receiverName       String     @map("receiver_name") @db.VarChar(255)
  receiverIdType     IdType?    @map("receiver_id_type")
  receiverIdNumber   String?    @map("receiver_id_number") @db.VarChar(20)
  receiverEmail      String?    @map("receiver_email") @db.VarChar(255)
  receiverPhone      String?    @map("receiver_phone") @db.VarChar(50)
  receiverAddress    String?    @map("receiver_address")
  receiverCityCode   String?    @map("receiver_city_code") @db.VarChar(10)
  receiverTaxRegime  TaxRegime? @map("receiver_tax_regime")
  receiverTaxResp    Json       @default("[]") @map("receiver_tax_resp")

  subtotal           Decimal @default(0) @db.Decimal(12, 2)
  discountAmount     Decimal @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxBase            Decimal @default(0) @map("tax_base") @db.Decimal(12, 2)
  ivaAmount          Decimal @default(0) @map("iva_amount") @db.Decimal(12, 2)
  icaAmount          Decimal @default(0) @map("ica_amount") @db.Decimal(12, 2)
  retefuenteAmount   Decimal @default(0) @map("retefuente_amount") @db.Decimal(12, 2)
  reteIvaAmount      Decimal @default(0) @map("reteiva_amount") @db.Decimal(12, 2)
  reteIcaAmount      Decimal @default(0) @map("reteica_amount") @db.Decimal(12, 2)
  totalTax           Decimal @default(0) @map("total_tax") @db.Decimal(12, 2)
  total              Decimal @default(0) @db.Decimal(12, 2)

  paymentMethodCode  String?  @map("payment_method_code") @db.VarChar(5)
  paymentMeansCode   String   @default("1") @map("payment_means_code") @db.VarChar(5)
  dueDate            DateTime? @map("due_date") @db.Date

  status              InvoiceStatus @default(draft)
  cufe                String?   @db.VarChar(255)
  qrCode              String?   @map("qr_code")
  dianResponse        Json      @default("{}") @map("dian_response")
  dianValidatedAt     DateTime? @map("dian_validated_at")
  dianRejectionReason String?   @map("dian_rejection_reason")
  xmlUrl              String?   @map("xml_url")
  pdfUrl              String?   @map("pdf_url")
  sentToEmail         Boolean   @default(false) @map("sent_to_email")
  sentAt              DateTime? @map("sent_at")

  notes              String?
  internalNotes      String?   @map("internal_notes")
  createdBy          String?   @map("created_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  items              InvoiceItem[]
  accountingTx       AccountingTransaction[]

  // Invoice number is unique per tenant (DIAN requirement — consecutive per NIT)
  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, storeId])
  @@index([saleId])
  @@index([customerId])
  @@index([tenantId, storeId, status])
  @@index([tenantId, storeId, createdAt])
  @@map("invoices")
}

// ─── Invoice Items ──────────────────────────────────────────────

model InvoiceItem {
  id               String   @id @default(uuid()) @db.Uuid
  invoiceId        String   @map("invoice_id") @db.Uuid
  invoice          Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId        String?  @map("product_id") @db.Uuid
  product          Product? @relation(fields: [productId], references: [id])
  serviceId        String?  @map("service_id") @db.Uuid
  service          Service? @relation(fields: [serviceId], references: [id])

  itemType         String   @default("product") @map("item_type") @db.VarChar(20)
  code             String?  @db.VarChar(50)
  description      String   @db.VarChar(500)
  quantity         Decimal  @default(1) @db.Decimal(10, 2)
  unitMeasure      String   @default("UN") @map("unit_measure") @db.VarChar(10)
  unitPrice        Decimal  @map("unit_price") @db.Decimal(12, 2)
  discountRate     Decimal  @default(0) @map("discount_rate") @db.Decimal(5, 2)
  discountAmount   Decimal  @default(0) @map("discount_amount") @db.Decimal(12, 2)
  subtotal         Decimal  @db.Decimal(12, 2)
  ivaRate          Decimal  @default(19) @map("iva_rate") @db.Decimal(5, 2)
  ivaAmount        Decimal  @default(0) @map("iva_amount") @db.Decimal(12, 2)
  isIvaExcluded    Boolean  @default(false) @map("is_iva_excluded")
  isIvaExempt      Boolean  @default(false) @map("is_iva_exempt")
  retefuenteRate   Decimal  @default(0) @map("retefuente_rate") @db.Decimal(5, 2)
  retefuenteAmount Decimal  @default(0) @map("retefuente_amount") @db.Decimal(12, 2)
  total            Decimal  @db.Decimal(12, 2)
  standardCode     String?  @map("standard_code") @db.VarChar(20)
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([invoiceId])
  @@map("invoice_items")
}

// ─── Accounting Transactions ────────────────────────────────────

model AccountingTransaction {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  storeId         String   @map("store_id") @db.Uuid
  store           Store    @relation(fields: [storeId], references: [id])

  transactionType AccountingTransactionType @map("transaction_type")
  category        String   @db.VarChar(100)
  subcategory     String?  @db.VarChar(100)

  saleId          String?  @map("sale_id") @db.Uuid
  sale            Sale?    @relation(fields: [saleId], references: [id])
  expenseId       String?  @map("expense_id") @db.Uuid
  expense         Expense? @relation(fields: [expenseId], references: [id])
  purchaseId      String?  @map("purchase_id") @db.Uuid
  purchase        Purchase? @relation(fields: [purchaseId], references: [id])
  invoiceId       String?  @map("invoice_id") @db.Uuid
  invoice         Invoice? @relation(fields: [invoiceId], references: [id])

  description     String   @db.VarChar(500)
  referenceNumber String?  @map("reference_number") @db.VarChar(50)

  grossAmount     Decimal  @map("gross_amount") @db.Decimal(12, 2)
  taxAmount       Decimal  @default(0) @map("tax_amount") @db.Decimal(12, 2)
  retentionAmount Decimal  @default(0) @map("retention_amount") @db.Decimal(12, 2)
  netAmount       Decimal  @map("net_amount") @db.Decimal(12, 2)

  ivaAmount        Decimal @default(0) @map("iva_amount") @db.Decimal(12, 2)
  retefuenteAmount Decimal @default(0) @map("retefuente_amount") @db.Decimal(12, 2)
  reteIvaAmount    Decimal @default(0) @map("reteiva_amount") @db.Decimal(12, 2)
  reteIcaAmount    Decimal @default(0) @map("reteica_amount") @db.Decimal(12, 2)
  icaAmount        Decimal @default(0) @map("ica_amount") @db.Decimal(12, 2)

  paymentMethod   String?  @map("payment_method") @db.VarChar(30)
  status          AccountingTransactionStatus @default(confirmed)
  transactionDate DateTime @map("transaction_date") @db.Date

  isReconciled    Boolean  @default(false) @map("is_reconciled")
  reconciledAt    DateTime? @map("reconciled_at")
  reconciledBy    String?  @map("reconciled_by") @db.Uuid

  createdBy       String?  @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([tenantId, storeId])
  @@index([tenantId, storeId, transactionType])
  @@index([tenantId, storeId, transactionDate])
  @@index([tenantId, storeId, category])
  @@index([saleId])
  @@index([invoiceId])
  @@map("accounting_transactions")
}

// ─── Tax Declarations ───────────────────────────────────────────

model TaxDeclaration {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  taxType          TaxType  @map("tax_type")
  periodType       String   @map("period_type") @db.VarChar(20)
  periodYear       Int      @map("period_year")
  periodMonth      Int?     @map("period_month")
  taxBase          Decimal  @default(0) @map("tax_base") @db.Decimal(12, 2)
  taxAmount        Decimal  @default(0) @map("tax_amount") @db.Decimal(12, 2)
  status           String   @default("pending") @db.VarChar(20)
  dueDate          DateTime? @map("due_date") @db.Date
  filedAt          DateTime? @map("filed_at")
  paidAt           DateTime? @map("paid_at")
  paymentReference String?  @map("payment_reference") @db.VarChar(100)
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, taxType, periodYear, periodMonth])
  @@map("tax_declarations")
}

// ─── Storefront ──────────────────────────────────────────────────

model Storefront {
  id                    String   @id @default(uuid()) @db.Uuid
  tenantId              String   @unique @map("tenant_id") @db.Uuid
  tenant                Tenant   @relation(fields: [tenantId], references: [id])
  displayName           String   @default("") @map("display_name") @db.VarChar(255)
  slug                  String?  @unique @db.VarChar(100)
  tagline               String?  @db.VarChar(300)
  description           String?
  logoUrl               String?  @map("logo_url")
  bannerUrl             String?  @map("banner_url")
  galleryUrls           Json     @default("[]") @map("gallery_urls")
  businessType          String?  @map("business_type") @db.VarChar(50)
  tags                  Json     @default("[]")
  publicEmail           String?  @map("public_email") @db.VarChar(255)
  publicPhone           String?  @map("public_phone") @db.VarChar(50)
  whatsapp              String?  @db.VarChar(50)
  instagram             String?  @db.VarChar(100)
  facebook              String?  @db.VarChar(255)
  tiktok                String?  @db.VarChar(100)
  website               String?  @db.VarChar(255)
  acceptsOrders         Boolean  @default(true) @map("accepts_orders")
  acceptsAppointments   Boolean  @default(true) @map("accepts_appointments")
  acceptsDelivery       Boolean  @default(false) @map("accepts_delivery")
  deliveryFee           Decimal  @default(0) @map("delivery_fee") @db.Decimal(12, 2)
  deliveryRadiusKm      Int      @default(10) @map("delivery_radius_km")
  minOrderAmount        Decimal  @default(0) @map("min_order_amount") @db.Decimal(12, 2)
  advancePaymentPercent Decimal  @default(0) @map("advance_payment_percent") @db.Decimal(5, 2)
  averageRating         Decimal  @default(0) @map("average_rating") @db.Decimal(3, 2)
  totalReviews          Int      @default(0) @map("total_reviews")
  totalOrdersCompleted  Int      @default(0) @map("total_orders_completed")
  isActive              Boolean  @default(false) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("storefronts")
}

model StorefrontReview {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  storeId       String?   @map("store_id") @db.Uuid
  store         Store?    @relation(fields: [storeId], references: [id])
  reviewerName  String    @map("reviewer_name") @db.VarChar(255)
  reviewerEmail String?   @map("reviewer_email") @db.VarChar(255)
  rating        Int
  comment       String?
  reply         String?
  repliedAt     DateTime? @map("replied_at")
  isVerified    Boolean   @default(false) @map("is_verified")
  productId     String?   @map("product_id") @db.Uuid
  serviceId     String?   @map("service_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("storefront_reviews")
}

model StorefrontOrder {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  storeId       String?  @map("store_id") @db.Uuid
  store         Store?   @relation(fields: [storeId], references: [id])
  orderNumber   String   @map("order_number") @db.VarChar(20)
  buyerName     String   @map("buyer_name") @db.VarChar(255)
  buyerEmail    String?  @map("buyer_email") @db.VarChar(255)
  buyerPhone    String?  @map("buyer_phone") @db.VarChar(50)
  buyerNotes    String?  @map("buyer_notes")
  items         Json     @default("[]")
  subtotal      Decimal  @default(0) @db.Decimal(12, 2)
  deliveryFee   Decimal  @default(0) @map("delivery_fee") @db.Decimal(12, 2)
  total         Decimal  @default(0) @db.Decimal(12, 2)
  paymentMethod String   @default("store") @map("payment_method") @db.VarChar(50)
  status        String   @default("pending") @db.VarChar(30)
  saleId        String?  @map("sale_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([status])
  @@map("storefront_orders")
}
