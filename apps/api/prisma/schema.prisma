// ─── Customers ───────────────────────────────────────────────────

model Customer {
  id                  String         @id @default(uuid()) @db.Uuid
  tenantId            String         @map("tenant_id") @db.Uuid
  storeId             String         @map("store_id") @db.Uuid
  store               Store          @relation(fields: [storeId], references: [id])
  customerNumber      String         @map("customer_number") @db.VarChar(20)
  firstName           String         @map("first_name") @db.VarChar(100)
  lastName            String         @map("last_name") @db.VarChar(100)
  email               String?        @db.VarChar(255)
  phone               String?        @db.VarChar(50)
  dateOfBirth         DateTime?      @map("date_of_birth") @db.Date
  avatarUrl           String?        @map("avatar_url")
  segment             CustomerSegment @default(new)
  loyaltyTier         LoyaltyTier    @default(bronze) @map("loyalty_tier")
  loyaltyPoints       Int            @default(0) @map("loyalty_points")
  tags                Json           @default("[]")
  source              String         @default("manual") @db.VarChar(50)
  totalPurchases      Int            @default(0) @map("total_purchases")
  totalSpent          Decimal        @default(0) @map("total_spent") @db.Decimal(12, 2)
  averageTicket       Decimal        @default(0) @map("average_ticket") @db.Decimal(12, 2)
  totalAppointments   Int            @default(0) @map("total_appointments")
  lastPurchaseAt      DateTime?      @map("last_purchase_at")
  lastAppointmentAt   DateTime?      @map("last_appointment_at")
  notes               String?
  isActive            Boolean        @default(true) @map("is_active")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  deletedAt           DateTime?      @map("deleted_at")

  sales        Sale[]
  appointments Appointment[]
  notes_rel    CustomerNote[]
  invoices     Invoice[]

  // Customer is unique per tenant — storeId = origin store only
  // Phone uniqueness enforced via partial index in DB (see migration)
  @@index([tenantId])
  @@index([tenantId, storeId])
  @@index([tenantId, segment])
  @@index([tenantId, loyaltyTier])
  @@index([tenantId, phone])
  @@index([tenantId, dateOfBirth])
  @@map("customers")
}

model CustomerNote {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  userId     String?  @map("user_id") @db.Uuid
  content    String
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([customerId])
  @@map("customer_notes")
}

// ─── Suppliers ───────────────────────────────────────────────────

model Supplier {
